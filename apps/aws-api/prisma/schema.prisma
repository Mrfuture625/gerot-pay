generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String      @id @default(cuid())
  walletAddress        String      @unique
  email                String?
  telegramId           String?
  telegramUsername     String?
  telegramCompleted    Boolean     @default(false)
  signupRewardEligible Boolean     @default(false)
  signupRewardClaimed  Boolean     @default(false)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  orders               Order[]
  vaultCards           VaultCard[]
  rewards              Reward[]
  referrals            Referral[]  @relation("Referrer")
}

model Order {
  id             String         @id @default(cuid())
  walletAddress  String
  vaultCardId    BigInt?
  txHash         String         @unique
  cardType       CardType
  paymentToken   PaymentToken
  cardHolderName String
  email          String
  phone          String?
  address        String?
  city           String?
  state          String?
  postalCode     String?
  country        String?
  status         OrderStatus    @default(PAID)
  createdAt      DateTime       @default(now())

  inventoryCard  CardInventory?
  vaultCard      VaultCard?
  user           User           @relation(fields: [walletAddress], references: [walletAddress])
}

model VaultCard {
  id            String   @id @default(cuid())
  walletAddress String
  vaultCardId   BigInt   @unique
  cardType      CardType
  orderId       String?  @unique
  active        Boolean  @default(true)
  frozen        Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [walletAddress], references: [walletAddress])
  order         Order?   @relation(fields: [orderId], references: [id])
}

model CardInventory {
  id             String   @id @default(cuid())
  cardNumber     String   @unique
  cvv            String
  expiryMonth    Int
  expiryYear     Int
  cardType       CardType

  assigned       Boolean  @default(false)
  assignedWallet String?
  assignedAt     DateTime?

  batch          String?
  orderId        String?  @unique
  importedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  order          Order?   @relation(fields: [orderId], references: [id])

  @@index([cardType, assigned])
  @@index([assignedWallet])
  @@index([batch])
}

model Reward {
  id               String     @id @default(cuid())
  walletAddress    String
  contractRewardId BigInt?
  createdAtOnchain BigInt?
  rewardType       RewardType
  amount           Decimal    @db.Decimal(18, 8)
  claimed          Boolean    @default(false)
  claimedAt        DateTime?
  createdAt        DateTime   @default(now())

  user             User       @relation(fields: [walletAddress], references: [walletAddress])
}

model Referral {
  id             String   @id @default(cuid())
  referrerWallet String
  referredWallet String   @unique
  rewardAmount   Decimal  @db.Decimal(18, 8)
  createdAt      DateTime @default(now())

  referrer       User     @relation("Referrer", fields: [referrerWallet], references: [walletAddress])
}

model Reload {
  id            String   @id @default(cuid())
  walletAddress String
  vaultCardId   BigInt
  amountUsd     Decimal  @db.Decimal(18, 8)
  txHash        String   @unique
  createdAt     DateTime @default(now())
}

model Withdrawal {
  id            String   @id @default(cuid())
  walletAddress String
  vaultCardId   BigInt
  amountUsd     Decimal  @db.Decimal(18, 8)
  txHash        String   @unique
  createdAt     DateTime @default(now())
}

model Coupon {
  id                 String       @id @default(cuid())

  code               String       @unique
  active             Boolean      @default(true)

  discountType       DiscountType
  discountValue      Decimal      @db.Decimal(18, 8)

  appliesTo          CouponTarget @default(ALL)

  minimumOrderAmount Decimal?     @db.Decimal(18, 8)

  maxUses            Int?
  usedCount          Int          @default(0)

  expiresAt          DateTime?

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

 onChainCouponId      String?
 onChainTxHash        String?

  @@index([code])
  @@index([active])
  @@index([appliesTo])
}

enum CardType {
  VIRTUAL
  PHYSICAL
}

enum PaymentToken {
  ETH
  USDC
  USDT
}

enum RewardType {
  SIGNUP
  PURCHASE
  REFERRAL
}

enum OrderStatus {
  PENDING
  PAID
  ASSIGNED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum CouponTarget {
  VIRTUAL_CARD
  PHYSICAL_CARD
  ALL
}